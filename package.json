{
  "name": "cs1301-review-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:java": "node scripts/generate-snippet-outputs.mjs",
    "prebuild": "npm run build:java",
    "build": "next build",
    "db:migrate": "node scripts/run-migrations.mjs",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "test:wf": "node node_modules/vitest/vitest.mjs run",
    "test:wf:headed": "node node_modules/vitest/vitest.mjs",
    "test:wf:debug": "node --inspect-brk node_modules/vitest/vitest.mjs run",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "verify": "node node_modules/vitest/vitest.mjs run --reporter=verbose",
    "test:browser-harness": "node node_modules/@playwright/test/cli.js test",
    "test:browser-harness:headed": "node node_modules/@playwright/test/cli.js test --headed",
    "test:browser-harness:debug": "node node_modules/@playwright/test/cli.js test --debug",
    "hooks:install": "cp .hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo '✅ Pre-commit hook installed'",
    "walkthrough": "npm run test:browser-harness:headed"
  },
  "dependencies": {
    "@brandon-gottshall/review-game-core": "file:../review-game-core",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "chevrotain": "^11.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-simple-code-editor": "^0.14.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "puppeteer": "^24.37.2",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
